@inject cleo.Services.ISettingsService SettingsService
@{
    var settings = await SettingsService.GetSettingsAsync();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @settings.SiteName</title>
    <link rel="icon" type="image/png" href="~/images/logo2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Footer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Button.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body-v2">
    <header>
        @await Html.PartialAsync("_Navbar")
    </header>

    <main class="dashboard-container-v2">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (Context.Session.GetString("Role") == "User")
    {
        <script>
        // === Cleo Daily Check-in In-App Scheduler ===
        (function () {
            const STORAGE_KEY = 'cleo_checkin_fired_v2';
            let schedulerInterval = null;
            let currentReminderTime = null;

            function getTodayStr() {
                const now = new Date();
                return now.getFullYear() + '-' + (now.getMonth() + 1) + '-' + now.getDate();
            }

            function hasAlreadyFiredToday() {
                try {
                    const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
                    return stored.date === getTodayStr();
                } catch { return false; }
            }

            function markFiredToday() {
                localStorage.setItem(STORAGE_KEY, JSON.stringify({
                    date: getTodayStr()
                }));
            }

            function fireCheckInNotification() {
                if (Notification.permission !== 'granted') return;
                
                console.log("Cleo: Firing daily check-in notification.");
                new Notification('🌸 Cleo Daily Check-in', {
                    body: 'Time to log your mood, symptoms, and thoughts. Your future self will thank you!',
                    icon: '/images/logo.png',
                    tag: 'cleo-daily-checkin'
                });
                markFiredToday();
            }

            function isTimePassed(reminderTime) {
                if (!reminderTime) return false;
                const now = new Date();
                const [rHour, rMin] = reminderTime.split(':').map(Number);
                const cHour = now.getHours();
                const cMin = now.getMinutes();
                
                if (cHour > rHour) return true;
                if (cHour === rHour && cMin >= rMin) return true;
                return false;
            }

            function startScheduler(reminderTime) {
                currentReminderTime = reminderTime;
                if (schedulerInterval) clearInterval(schedulerInterval);

                console.log("Cleo: Scheduler started for " + reminderTime);

                // Check immediately
                if (!hasAlreadyFiredToday() && isTimePassed(reminderTime)) {
                    fireCheckInNotification();
                }

                schedulerInterval = setInterval(function () {
                    if (!currentReminderTime) return;
                    if (hasAlreadyFiredToday()) return;

                    if (isTimePassed(currentReminderTime)) {
                        fireCheckInNotification();
                    }
                }, 30000); // every 30s
            }

            async function fetchAndRefresh() {
                try {
                    const resp = await fetch('/Reminders/GetCheckInTime');
                    if (!resp.ok) return;
                    const data = await resp.json();
                    
                    if (!data.enabled || !data.time) {
                        if (schedulerInterval) clearInterval(schedulerInterval);
                        currentReminderTime = null;
                        return;
                    }

                    if (data.time !== currentReminderTime) {
                        startScheduler(data.time);
                    }
                } catch (e) {
                    console.warn('Cleo scheduler: poll failed.', e);
                }
            }

            async function initCheckInScheduler() {
                if (!('Notification' in window)) return;
                
                // If permission is already granted, start polling
                if (Notification.permission === 'granted') {
                    await fetchAndRefresh();
                    setInterval(fetchAndRefresh, 120000);
                } 
                // If it's the reminders page, we don't auto-request to avoid interrupting the user's flow
                // The reminders page has its own "Send Test" button which handles permission.
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initCheckInScheduler);
            } else {
                initCheckInScheduler();
            }
        })();
        </script>
    }
</body>
</html>
