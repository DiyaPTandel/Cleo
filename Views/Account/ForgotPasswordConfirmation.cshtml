@{
    Layout = null;
    ViewData["Title"] = "Email Sent";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CLEO</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/global.css" />
    <link rel="stylesheet" href="~/css/Login.css" />
</head>
<body style="margin: 0; padding: 0; background-color: white;">
    <div class="auth-page-v3">
        <!-- Back Navigation Icon -->
        <a asp-action="Login" asp-controller="Public" class="back-nav-v3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </a>

        <div class="auth-container-v3" style="max-width: 500px; grid-template-columns: 1fr;">
            <!-- Simple Content Section -->
            <div class="auth-form-section-v3" style="text-align: center;">
                <div class="auth-lotus-logo-v3" style="margin: 0 auto 24px auto;">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#10517F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>

                <div class="auth-header-v3">
                    <h1>Check Your Email</h1>
                    <p>We've sent a password reset link to your email address. It should arrive in a few minutes.</p>
                </div>

                <div style="margin-top: 32px;">
                    <a asp-action="Login" asp-controller="Public" class="auth-btn-primary-v3" style="text-decoration: none; display: flex; justify-content: center; align-items: center;">
                        Return to Login
                    </a>
                </div>

                <div class="auth-footer-v3" style="margin-top: 32px;">
                    <p>Didn't receive the email? <a href="/Public/ForgotPassword">Resend Link</a></p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
