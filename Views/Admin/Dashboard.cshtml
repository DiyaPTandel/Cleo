@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/AdminDashboard.css" asp-append-version="true" />
}

<div class="admin-dashboard-v3">
    <div class="dashboard-header-v3">
        <div class="header-info-v3">
            <h1 class="page-title-v3">Dashboard Overview</h1>
            <p class="subtitle-v3">Welcome back, here's what's happening with your app today.</p>
        </div>
        <div class="header-actions-v3">
            <button class="btn-refresh-v3" onclick="window.location.reload()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                Refresh Data
            </button>
            <button class="btn-primary-v3" onclick="window.location.href='/Admin/Content'">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add Content
            </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid-v3">
        <div class="stat-card-v3">
            <div class="stat-top-v3">
                <div class="stat-icon-v3 purple-v3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <div class="stat-trend-v3 up">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="18 15 12 9 6 15"></polyline></svg>
                    12.5%
                </div>
            </div>
            <div class="stat-main-v3">
                <span class="stat-label-v3">Total Users</span>
                <h2 class="stat-value-v3">@ViewBag.Stats.TotalUsers</h2>
            </div>
        </div>

        <div class="stat-card-v3">
            <div class="stat-top-v3">
                <div class="stat-icon-v3 pink-v3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.82-8.82 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                </div>
                <div class="stat-trend-v3 up">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="18 15 12 9 6 15"></polyline></svg>
                    5.2%
                </div>
            </div>
            <div class="stat-main-v3">
                <span class="stat-label-v3">Active Users</span>
                <h2 class="stat-value-v3">@ViewBag.Stats.ActiveUsers</h2>
            </div>
        </div>

        <div class="stat-card-v3">
            <div class="stat-top-v3">
                <div class="stat-icon-v3 blue-v3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <div class="stat-trend-v3 down">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    2.1%
                </div>
            </div>
            <div class="stat-main-v3">
                <span class="stat-label-v3">Period Logs</span>
                <h2 class="stat-value-v3">@ViewBag.Stats.CyclesLogged</h2>
            </div>
        </div>

        <div class="stat-card-v3">
            <div class="stat-top-v3">
                <div class="stat-icon-v3 green-v3">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <div class="stat-trend-v3 neutral">Today</div>
            </div>
            <div class="stat-main-v3">
                <span class="stat-label-v3">System Health</span>
                <h2 class="stat-value-v3">@ViewBag.Stats.SystemHealth</h2>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Row -->
    <div class="dashboard-row-v3">
        <div class="chart-column-v3">
            <div class="content-card-v3">
                <div class="card-header-v3">
                    <h3 class="card-title-v3">User Growth</h3>
                    <div class="card-options-v3">Total Users : @ViewBag.Stats.TotalUsers <span class="trend-percent-v3 up">+12.5%</span></div>
                </div>
                <div class="chart-container-v3" style="position: relative; height: 220px; width: 100%;">
                    <canvas id="userGrowthChart"></canvas>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const ctx = document.getElementById('userGrowthChart').getContext('2d');
                
                // Get data from ViewBag
                const labels = @Html.Raw(Json.Serialize(ViewBag.ChartLabels));
                const data = @Html.Raw(Json.Serialize(ViewBag.ChartData));

                const gradient = ctx.createLinearGradient(0, 0, 0, 200);
                gradient.addColorStop(0, 'rgba(139, 92, 246, 0.3)');
                gradient.addColorStop(1, 'rgba(139, 92, 246, 0)');

                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'User Growth',
                            data: data,
                            borderColor: '#8B5CF6',
                            borderWidth: 3,
                            fill: true,
                            backgroundColor: gradient,
                            tension: 0.4,
                            pointRadius: 4,
                            pointBackgroundColor: '#8B5CF6',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointHoverRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                titleColor: '#fff',
                                bodyColor: '#fff',
                                padding: 12,
                                cornerRadius: 8,
                                displayColors: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f1f5f9' },
                                ticks: { 
                                    color: '#64748b',
                                    font: { size: 11 },
                                    stepSize: 1
                                }
                            },
                            x: {
                                grid: { display: false },
                                ticks: { 
                                    color: '#64748b',
                                    font: { size: 11 }
                                }
                            }
                        }
                    }
                });
            });
        </script>

        <div class="activity-column-v3">
            <div class="content-card-v3">
                <div class="card-header-v3">
                    <h3 class="card-title-v3">Recent User Activity</h3>
                    <a href="#" class="view-all-v3">View All</a>
                </div>
                <div class="activity-table-container-v3">
                    <table class="activity-table-v3">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>ID</th>
                                <th>Status</th>
                                <th>Last Active</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var activity in ViewBag.RecentActivity)
                            {
                                <tr>
                                    <td>
                                        <div class="user-cell-v3">
                                            <img src="https://ui-avatars.com/api/?name=@activity.User&background=random" alt="User" class="user-avatar-v3" />
                                            <span>@activity.User</span>
                                        </div>
                                    </td>
                                    <td>#CLO-@activity.User.Substring(0, 3).ToUpper()</td>
                                    <td><span class="status-badge-v3 online">Online</span></td>
                                    <td>@activity.Time</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
