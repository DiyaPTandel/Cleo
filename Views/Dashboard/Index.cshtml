@{
    ViewData["Title"] = "Dashboard";
    Layout = "_DashboardLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Dashboard.css" asp-append-version="true" />
    <style>
        .mood-option {
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .mood-option:hover {
            background-color: #EBF8FF;
            border-color: var(--primary-color);
            transform: translateY(-2px);
        }
        .mood-option.active {
            border-color: #EDF2F7 !important;
            background-color: #EBF8FF !important;
            box-shadow: 0 4px 12px rgba(16, 81, 127, 0.1);
        }
    </style>
}

<div class="dashboard-v2">
    <div class="welcome-header">
        <h1>Welcome back, @ViewBag.UserName!</h1>
        <p>Here's your cycle overview for today</p>
    </div>

    @if (TempData["AITip"] != null)
    {
        <div class="ai-tip-dashboard">
            <div class="ai-tip-icon">✨</div>
            <div class="ai-tip-content">
                <h4>Cleo AI Insight</h4>
                <p>@TempData["AITip"]</p>
            </div>
        </div>
    }

    <div class="top-stats-grid">
        <!-- Next Period Card -->
        <div class="stat-card-v2">
            <div class="card-top">
                <div class="card-label">
                    <p class="label-small">Next Period</p>
                    <h2 class="label-large">@ViewBag.NextPeriodDate</h2>
                </div>
                <div class="card-icon icon-blue">
                    <span>📅</span>
                </div>
            </div>
            <p class="card-comment">In @ViewBag.DaysUntilNextPeriod days</p>
            <div class="progress-bar-container">
                <div class="progress-bar" style="width: @(Math.Clamp(100 - (ViewBag.DaysUntilNextPeriod * 100 / 28), 0, 100))%;"></div>
            </div>
        </div>

        <!-- Ovulation Card -->
        <div class="stat-card-v2">
            <div class="card-top">
                <div class="card-label">
                    <p class="label-small">Ovulation Day</p>
                    <h2 class="label-large">@ViewBag.OvulationDay</h2>
                </div>
                <div class="card-icon icon-purple">
                    <span>💜</span>
                </div>
            </div>
            <p class="card-comment">@(ViewBag.OvulationDaysUntil > 0 ? $"In {ViewBag.OvulationDaysUntil} days" : "Passed")</p>
            <span class="status-pill-purple">Fertile Window</span>
        </div>

        <!-- Cycle Day Card -->
        <div class="stat-card-v2 card-dark-blue">
            <div class="card-top">
                <div class="card-label">
                    <p class="label-small-white">Current cycle Day</p>
                    <h2 class="label-xl-white">@ViewBag.CycleDay</h2>
                    <p class="label-small-white">of @ViewBag.CycleLength days</p>
                </div>
                <div class="progress-ring-container">
                    <div class="progress-ring-v2" style="--progress: @(ViewBag.CycleDay * 100 / ViewBag.CycleLength)%;">
                        <span>@(ViewBag.CycleDay * 100 / ViewBag.CycleLength)%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="middle-layout">
        <div class="left-column">
            <!-- Quick Actions -->
            <div class="section-card quick-actions-card">
                <div class="section-header">
                    <span class="section-icon">💧</span>
                    <h3>Quick Actions</h3>
                </div>
                <div class="actions-buttons-v2">
                    <a asp-action="LogPeriod" class="btn-action-primary">+ Log Period</a>
                    <a asp-action="Notes" class="btn-action-primary">Add Note</a>
                </div>
            </div>

            <!-- Mood Section -->
            <div class="section-card mood-select-card">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                    <h3 style="margin-bottom: 0;">How are you feeling today?</h3>
                    <a asp-action="Mood" class="btn-text" style="font-size: 0.75rem; padding: 0.25rem 0.75rem;">View History</a>
                </div>
                <div id="moodSuccessMsg" style="display: none; background: #D6BCFA; color: white; padding: 0.75rem; text-align: center; border-radius: var(--radius-md); margin-bottom: 1rem; font-weight: bold;">
                    Mood logged for today! 💜
                </div>
                <form id="quickMoodForm" method="post" asp-action="LogMood" asp-controller="Dashboard">
                    <input type="hidden" name="description" value="" />
                    <input type="hidden" name="mood" id="quickMoodInput" value="" />
                    <div class="mood-grid-v2">
                        <button type="button" class="mood-option @(ViewBag.Mood == "Happy" ? "active" : "")" onclick="submitQuickMood('Happy', this)">
                            <span class="emoji-icon">😊</span><span class="mood-label">Happy</span>
                        </button>
                        <button type="button" class="mood-option @(ViewBag.Mood == "Calm" ? "active" : "")" onclick="submitQuickMood('Calm', this)">
                            <span class="emoji-icon">😌</span><span class="mood-label">Calm</span>
                        </button>
                        <button type="button" class="mood-option @(ViewBag.Mood == "Tired" ? "active" : "")" onclick="submitQuickMood('Tired', this)">
                            <span class="emoji-icon">😴</span><span class="mood-label">Tired</span>
                        </button>
                        <button type="button" class="mood-option @(ViewBag.Mood == "Sad" ? "active" : "")" onclick="submitQuickMood('Sad', this)">
                            <span class="emoji-icon">😔</span><span class="mood-label">Sad</span>
                        </button>
                        <button type="button" class="mood-option @(ViewBag.Mood == "Angry" ? "active" : "")" onclick="submitQuickMood('Angry', this)">
                            <span class="emoji-icon">😠</span><span class="mood-label">Angry</span>
                        </button>
                        <button type="button" class="mood-option @(ViewBag.Mood == "Excited" ? "active" : "")" onclick="submitQuickMood('Excited', this)">
                            <span class="emoji-icon">🤩</span><span class="mood-label">Excited</span>
                        </button>
                        <button type="button" class="mood-option @(ViewBag.Mood == "Anxious" ? "active" : "")" onclick="submitQuickMood('Anxious', this)">
                            <span class="emoji-icon">😟</span><span class="mood-label">Anxious</span>
                        </button>
                        <button type="button" class="mood-option @(ViewBag.Mood == "Sensitive" ? "active" : "")" onclick="submitQuickMood('Sensitive', this)">
                            <span class="emoji-icon">🥺</span><span class="mood-label">Sensitive</span>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Insights Section -->
            <div class="section-card insights-card">
                <div class="section-header">
                    <span class="section-icon">📈</span>
                    <h3>Cycle Insights</h3>
                </div>
                <div class="insights-list">
                    <div class="insight-item blue-bg">
                        <span class="dot-blue"></span>
                        <div class="insight-text">
                            <strong>@(ViewBag.IsRegular ? "Regular Cycle Pattern" : "Irregular Cycle Pattern")</strong>
                            <p>@(ViewBag.IsRegular ? "Your cycle has been consistent recently." : "Your cycle shows some variations recently.")</p>
                        </div>
                    </div>
                    <div class="insight-item purple-bg">
                        <span class="dot-purple"></span>
                        <div class="insight-text">
                            <strong>Approaching Fertile Window</strong>
                            <p>Your fertile window starts in @ViewBag.DaysUntilFertile days</p>
                        </div>
                    </div>
                    <div class="insight-item blue-bg">
                        <span class="dot-blue"></span>
                        <div class="insight-text">
                            <strong>Average Cycle Length</strong>
                            <p>Your average cycle is @ViewBag.AvgCycleLength days</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="right-column">

            <!-- Recent Notes -->
            <div class="section-card notes-widget">
                <h3>Recent Notes</h3>
                <div class="notes-stack">
                    @if (ViewBag.Notes != null)
                    {
                        @foreach (var note in ViewBag.Notes)
                        {
                            <div class="note-pill">
                                <p class="note-preview">@note</p>
                            </div>
                        }
                    }
                </div>
                <div class="center-btn">
                    <a asp-action="Notes" class="btn-text">View All Notes</a>
                </div>
            </div>

            <!-- Health Tip -->
            <div class="health-tip-purple">
                <div class="tip-header-v2">
                    <span>💡</span>
                    <h3>Today's Health Tip</h3>
                </div>
                <p class="tip-body-v2">
                    Stay hydrated! Drinking plenty of water can help reduce bloating and PMS symptoms during your cycle.
                </p>
                <a asp-action="Tips" class="btn-more-tips">more tips</a>
            </div>

            <!-- Reminders -->
            <div class="section-card reminders-timeline-card">
                <div class="section-header-row">
                    <h3>Upcoming Reminders</h3>
                    <div class="notification-toggle-wrapper">
                        <span class="toggle-label">Push Alerts</span>
                        <label class="switch-v2">
                            <input type="checkbox" id="notificationToggle">
                            <span class="slider-v2 round"></span>
                        </label>
                    </div>
                </div>
                <div class="timeline-v2">
                    @if (ViewBag.UpcomingReminders != null && ((List<cleo.Models.Reminder>)ViewBag.UpcomingReminders).Any())
                    {
                        foreach (var reminder in (List<cleo.Models.Reminder>)ViewBag.UpcomingReminders)
                        {
                            var daysLeft = (reminder.ReminderDate.Date - DateTime.UtcNow.Date).Days;
                            string timeLabel = daysLeft switch
                            {
                                0 => "Today",
                                1 => "Tomorrow",
                                _ => $"In {daysLeft} days"
                            };

                            <div class="timeline-item-v2 @reminder.Type.ToLower()">
                                <div class="timeline-marker"></div>
                                <div class="timeline-content">
                                    <span class="timeline-time">@timeLabel</span>
                                    <p class="timeline-title">@reminder.Title</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="no-reminders">No upcoming reminders</p>
                    }
                </div>
                <div class="center-btn">
                    <a asp-action="Manage" asp-controller="Reminders" class="btn-reminders-v2">Manage Reminders</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function submitQuickMood(mood, buttonElement) {
            document.getElementById('quickMoodInput').value = mood;
            const form = document.getElementById('quickMoodForm');
            const data = new FormData(form);
            
            // Remove active class from all
            document.querySelectorAll('.mood-option').forEach(btn => btn.classList.remove('active'));
            // Add active to clicked
            buttonElement.classList.add('active');

            fetch(form.action, {
                method: 'POST',
                body: data
            })
            .then(response => {
                if(response.ok) {
                    const msg = document.getElementById('moodSuccessMsg');
                    msg.style.display = 'block';
                    setTimeout(() => msg.style.display = 'none', 3000);
                }
            })
            .catch(error => console.error('Error logging mood:', error));
        }

        document.addEventListener('DOMContentLoaded', function() {
            const toggle = document.getElementById('notificationToggle');
            const REMINDER_SENT_KEY = 'cleo_reminders_sent_today';
            
            // 1. Initialize Toggle State from localStorage
            const isEnabled = localStorage.getItem('cleo_notifications_enabled') === 'true';
            toggle.checked = isEnabled;
            
            // 2. Handle Toggle Change
            toggle.addEventListener('change', function() {
                localStorage.setItem('cleo_notifications_enabled', toggle.checked);
                if (toggle.checked) {
                    requestNotificationPermission();
                }
            });

            function requestNotificationPermission() {
                if (!("Notification" in window)) {
                    console.log("This browser does not support desktop notification");
                    return;
                }
                
                if (Notification.permission !== "granted") {
                    Notification.requestPermission();
                }
            }

            // 3. Smart Notification Logic
            const checkAndTriggerNotifications = () => {
                if (Notification.permission !== "granted" || !toggle.checked) return;

                // We inject the reminders from ViewBag into a JS array
                const upcomingReminders = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.UpcomingReminders));
                const today = new Date().toISOString().split('T')[0];
                const sentReminders = JSON.parse(localStorage.getItem(REMINDER_SENT_KEY) || '{}');

                // If it's a new day, clear the sent cache
                if (sentReminders.date !== today) {
                    sentReminders.date = today;
                    sentReminders.ids = [];
                }

                upcomingReminders.forEach(reminder => {
                    const reminderDateStr = new Date(reminder.ReminderDate).toISOString().split('T')[0];
                    
                    // Trigger if it's due today and hasn't been sent yet
                    if (reminderDateStr === today && !sentReminders.ids.includes(reminder.Id)) {
                        new Notification("Cleo Reminder", {
                            body: reminder.Title,
                            icon: "/images/logo2.png" // Using the premium logo
                        });
                        sentReminders.ids.push(reminder.Id);
                    }
                });

                localStorage.setItem(REMINDER_SENT_KEY, JSON.stringify(sentReminders));
            };

            if (isEnabled) {
                checkAndTriggerNotifications();
            }
        });

        function submitMood(mood) {
            document.getElementById('selectedMood').value = mood;
            document.getElementById('moodForm').submit();
        }
    </script>
}
