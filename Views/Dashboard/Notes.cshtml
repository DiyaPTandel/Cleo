@{
    ViewData["Title"] = "My Notes";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Notes.css" />
}

<div class="notes-page-v3">
    <!-- Header with Back Arrow -->
    <div class="notes-header-v3">
        <div class="header-left-v3">
            <a asp-action="Index" class="back-link-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="back-arrow-svg">
                    <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
            <div class="title-group-v3">
                <h1>My Notes</h1>
                <p>Track symptoms, feelings, and important observations</p>
            </div>
        </div>
        <div class="header-right-v3">
            <button class="btn-add-note-v3">+ Add note</button>
        </div>
    </div>

    <!-- Notes Grid -->
    <div class="notes-grid-v3">
        @foreach (var note in ViewBag.Notes)
        {
            <div class="note-card-v3">
                <div class="note-card-header-v3">
                    <div class="note-meta-v3">
                        <span class="note-date-v3">@note.Date</span>
                        <h3 class="note-title-v3">@note.Title</h3>
                    </div>
                    <div class="note-card-actions-v3">
                        <button class="icon-action-btn-v3" title="Edit" onclick="openEditModal(@note.Id, '@note.Type', '@note.Title', `@note.Content`)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                        </button>
                        <button class="icon-action-btn-v3 delete" title="Delete" onclick="openDeleteModal(@note.Id, '@note.Type')">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                        </button>
                    </div>
                </div>
                <p class="note-body-text-v3">@note.Content</p>
            </div>
        }
    </div>

    <!-- Note Taking Tips -->
    <div class="notes-tips-card-v3">
        <h3 class="tips-title-v3">💡 Note Taking Tips</h3>
        <ul class="tips-list-v3">
            <li>Track symptoms like cramps, headaches, or mood changes</li>
            <li>Note any medications or supplements you take</li>
            <li>Record exercise, diet changes, or sleep patterns</li>
        </ul>
    </div>
</div>

<!-- Modal Container -->
<div id="addNoteModal" class="modal-overlay-v3" style="display: none;">
    <div class="modal-card-v3">
        <h2 class="modal-title-v3">Add new note</h2>
        <form asp-action="AddNote" method="post" class="modal-form-v3">
            @Html.AntiForgeryToken()
            <div class="form-group-v3">
                <input type="text" name="title" placeholder="Note Title (Optional)" />
            </div>
            <div class="form-group-v3">
                <textarea name="content" placeholder="Start typing your note here..." required></textarea>
            </div>
            <div class="modal-footer-v3">
                <button type="submit" class="btn-modal-save-v3">Save Note</button>
                <button type="button" class="btn-modal-cancel-v3" onclick="closeAddModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div id="editNoteModal" class="modal-overlay-v3" style="display: none;">
    <div class="modal-card-v3">
        <h2 class="modal-title-v3">Edit note</h2>
        <form asp-action="EditNote" method="post" class="modal-form-v3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editNoteId" />
            <input type="hidden" name="type" id="editNoteType" />
            <div class="form-group-v3">
                <input type="text" name="title" id="editNoteTitle" placeholder="Note Title (Optional)" />
            </div>
            <div class="form-group-v3">
                <textarea name="content" id="editNoteContent" placeholder="Start typing your note here..." required></textarea>
            </div>
            <div class="modal-footer-v3">
                <button type="submit" class="btn-modal-save-v3">Update Note</button>
                <button type="button" class="btn-modal-cancel-v3" onclick="closeEditModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteNoteModal" class="modal-overlay-v3" style="display: none;">
    <div class="modal-card-v3" style="text-align: center;">
        <div style="width: 60px; height: 60px; background: #FEF2F2; color: #EF4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
        </div>
        <h2 class="modal-title-v3">Delete Note?</h2>
        <p style="color: #64748B; margin-bottom: 2rem;">Are you sure you want to delete this note? This action cannot be undone.</p>
        <form asp-action="DeleteNote" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteNoteId" />
            <input type="hidden" name="type" id="deleteNoteType" />
            <div class="modal-footer-v3" style="flex-direction: column; gap: 0.75rem;">
                <button type="submit" class="btn-modal-save-v3" style="background: #EF4444; width: 100%;">Yes, Delete Note</button>
                <button type="button" class="btn-modal-cancel-v3" onclick="closeDeleteModal()" style="width: 100%;">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openAddModal() { document.getElementById('addNoteModal').style.display = 'flex'; }
    function closeAddModal() { document.getElementById('addNoteModal').style.display = 'none'; }
    
    function openEditModal(id, type, title, content) {
        document.getElementById('editNoteId').value = id;
        document.getElementById('editNoteType').value = type;
        document.getElementById('editNoteTitle').value = title || "";
        document.getElementById('editNoteContent').value = content || "";
        document.getElementById('editNoteModal').style.display = 'flex';
    }
    
    function closeEditModal() { document.getElementById('editNoteModal').style.display = 'none'; }

    function openDeleteModal(id, type) {
        document.getElementById('deleteNoteId').value = id;
        document.getElementById('deleteNoteType').value = type;
        document.getElementById('deleteNoteModal').style.display = 'flex';
    }

    function closeDeleteModal() { document.getElementById('deleteNoteModal').style.display = 'none'; }
    
    document.querySelector('.btn-add-note-v3').onclick = openAddModal;
</script>
