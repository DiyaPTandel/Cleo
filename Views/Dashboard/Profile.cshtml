@{
    ViewData["Title"] = "Profile";
    Layout = "_DashboardLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Profile.css" />
}

<div class="profile-v2">
    <div class="profile-header-v2">
        <h1>My Profile</h1>
        <p>Manage your account and cycle information</p>
    </div>

    @if (TempData["ProfileMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["ProfileMessage"]
        </div>
    }

    <!-- User Banner Card -->
    <div class="profile-banner-card">
        <div class="banner-avatar">
            <img src="https://ui-avatars.com/api/?name=@(ViewBag.Profile.Name)&background=EBF8FF&color=10517F&size=100" alt="Avatar" />
        </div>
        <div class="banner-info">
            <h2>@ViewBag.Profile.Name</h2>
            <p>@ViewBag.Profile.Email</p>
        </div>
    </div>

    <!-- Info Form Section -->
    <form asp-action="UpdateProfile" method="post" class="profile-form-v2">
        @Html.AntiForgeryToken()
        <div class="profile-section-card">
            <div class="form-grid-v2">
                <div class="form-group-v2">
                    <label>👤 Full Name</label>
                    <input type="text" name="name" value="@ViewBag.Profile.Name" required />
                </div>
                <div class="form-group-v2">
                    <label>✉️ Email Address</label>
                    <input type="email" value="@ViewBag.Profile.Email" readonly class="input-readonly" />
                    <small class="form-hint">Email cannot be changed</small>
                </div>
                <div class="form-group-v2">
                    <label>📅 Date of Birth</label>
                    <input type="date" name="dob" value="@ViewBag.Profile.DateOfBirth" />
                </div>
                <div class="form-group-v2">
                    <label>📊 Age Group</label>
                    <select name="ageGroup" class="form-select-v2">
                        <option value="Under 18" selected="@(ViewBag.Profile.AgeGroup == "Under 18")">Under 18</option>
                        <option value="18-24" selected="@(ViewBag.Profile.AgeGroup == "18-24")">18-24</option>
                        <option value="25-34" selected="@(ViewBag.Profile.AgeGroup == "25-34")">25-34</option>
                        <option value="35-44" selected="@(ViewBag.Profile.AgeGroup == "35-44")">35-44</option>
                        <option value="45+" selected="@(ViewBag.Profile.AgeGroup == "45+")">45+</option>
                    </select>
                </div>
            </div>

            <h3 class="subsection-title">Cycle information</h3>
            <div class="form-grid-v2">
                <div class="form-group-v2">
                    <label>Cycle Length (days)</label>
                    <input type="number" name="cycleLength" value="@ViewBag.Profile.CycleLength" min="15" max="50" required />
                </div>
                <div class="form-group-v2">
                    <label>Period Length (days)</label>
                    <input type="number" name="periodLength" value="@ViewBag.Profile.PeriodLength" min="1" max="15" required />
                </div>
            </div>

            <div class="form-actions-v2">
                <button type="submit" class="btn-profile-primary">Save Changes</button>
                <button type="button" class="btn-profile-secondary" onclick="window.location.reload()">Discard</button>
            </div>
        </div>
    </form>

    <!-- Stats Grid Row -->
    <div class="profile-stats-row">
        <div class="stat-pill-card">
            <p class="pill-label">Member since</p>
            <h3 class="pill-value">@ViewBag.Profile.JoinDate</h3>
        </div>
        <div class="stat-pill-card">
            <p class="pill-label">Cycles Tracked</p>
            <h3 class="pill-value text-blue">@ViewBag.Profile.TotalCycles</h3>
        </div>
        <div class="stat-pill-card">
            <p class="pill-label">Notes Created</p>
            <h3 class="pill-value">@ViewBag.Profile.TotalMoods</h3>
        </div>
        <div class="stat-pill-card">
            <p class="pill-label">Mood Entries</p>
            <h3 class="pill-value">@ViewBag.Profile.TotalMoods</h3>
        </div>
    </div>

    <!-- Security Sections -->
    <div class="profile-section-card">
        <h3 class="subsection-title-danger">Delete Account</h3>
        <p class="danger-desc">Want to delete your account?</p>
        <button class="btn-danger-outline" onclick="openDeleteModal()">Delete Account</button>
        <p class="danger-warning">Warning: This action cannot be undone. All your data will be permanently deleted.</p>
    </div>

    <form asp-controller="Public" asp-action="Logout" method="post" class="profile-logout-form">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-profile-logout">
            <span>🚪</span> Logout from Cleo
        </button>
    </form>
</div>

<!-- Delete Modal -->
<div id="deleteAccountModal" class="modal-overlay-v3" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div class="modal-card-v3" style="background: white; padding: 2rem; border-radius: 1rem; max-width: 400px; width: 90%; text-align: center; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);">
        <div style="width: 64px; height: 64px; background: #FEF2F2; color: #EF4444; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        <h2 style="font-size: 1.5rem; font-weight: 800; color: #111827; margin-bottom: 0.5rem;">Delete Account?</h2>
        <p style="color: #6B7280; margin-bottom: 2rem;">This action is permanent and will delete all your cycle history and data. Are you absolutely sure?</p>
        
        <form asp-action="DeleteAccount" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" style="width: 100%; padding: 0.85rem; background: #EF4444; color: white; border: none; border-radius: 0.75rem; font-weight: 700; margin-bottom: 0.75rem; cursor: pointer;">Yes, Delete Everything</button>
            <button type="button" onclick="closeDeleteModal()" style="width: 100%; padding: 0.85rem; background: #F3F4F6; color: #374151; border: none; border-radius: 0.75rem; font-weight: 700; cursor: pointer;">Cancel</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openDeleteModal() { document.getElementById('deleteAccountModal').style.display = 'flex'; }
        function closeDeleteModal() { document.getElementById('deleteAccountModal').style.display = 'none'; }

        document.addEventListener('DOMContentLoaded', function () {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.classList.add('fade-out');
                    setTimeout(() => {
                        alert.style.display = 'none';
                    }, 500); // Match CSS transition duration
                }, 3000); // 3 seconds visibility
            });
        });
    </script>
}
