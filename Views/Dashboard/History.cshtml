@{
    ViewData["Title"] = "Period History";
    Layout = "_DashboardLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/History.css" asp-append-version="true" />
    <style>
        /* Embedded Fallback Styles to ensure layout structure */
        .history-page-v3 { background-color: #F7FAFD; min-height: 100vh; padding: 2rem; display: block; font-family: 'Inter', sans-serif; }
        .stats-grid-v3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
        .stat-card-v3 { background: white; padding: 1.5rem; border-radius: 1rem; border: 1px solid #E2E8F0; }
        .stat-card-v3 .label { display: block; font-size: 0.85rem; font-weight: 700; color: #4A5568; margin-bottom: 0.5rem; }
        .stat-card-v3 .value { font-size: 1.75rem; font-weight: 800; color: #10517F; }
        .history-table-card-v3 { background: white; border-radius: 1rem; border: 1px solid #E2E8F0; overflow: hidden; margin-bottom: 2rem; }
        .history-table-v3 { width: 100%; border-collapse: collapse; }
        .history-table-v3 th { background: #EEF7FF; color: #4A88B7; padding: 1rem; text-align: left; }
        .history-table-v3 td { padding: 1rem; border-bottom: 1px solid #EDF2F7; }
        .insights-bar-v3 { background: #155383; color: white; padding: 2rem; border-radius: 1rem; }
    </style>
}

<div class="history-page-v3">
    <!-- Header -->
    <div class="history-header-v3">
        <h1>Period History</h1>
        <p>View and manage your cycle records</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid-v3">
        <div class="stat-card-v3">
            <span class="label">Total Cycles</span>
            <span class="value">@ViewBag.TotalCycles</span>
        </div>
        <div class="stat-card-v3">
            <span class="label">Avg Cycle Length</span>
            <span class="value">@ViewBag.AvgCycleLength</span>
        </div>
        <div class="stat-card-v3">
            <span class="label">Last Period</span>
            <span class="value value-blue">@ViewBag.LastPeriod</span>
        </div>
        <div class="stat-card-v3">
            <span class="label">Next Expected</span>
            <span class="value value-black">@ViewBag.NextExpected</span>
        </div>
    </div>

    <!-- History Table Card -->
    <div class="history-table-card-v3">
        <table class="history-table-v3">
            <thead>
                <tr>
                    <th>Cycle #</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Cycle Length</th>
                    <th>Flow</th>
                    <th class="actions-header">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ 
                    int count = ViewBag.TotalCycles;
                    var list = (List<cleo.Models.CycleTrack>)ViewBag.HistoryList;
                }
                @for (int idx = 0; idx < list.Count; idx++)
                {
                    var cycle = list[idx];
                    string cycleLenStr = "---";
                    if (idx < list.Count - 1)
                    {
                        cycleLenStr = (list[idx].StartDate - list[idx + 1].StartDate).TotalDays + " days";
                    }
                    <tr>
                        <td class="bold">@(count--)</td>
                        <td>@cycle.StartDate.ToString("MMM dd, yyyy")</td>
                        <td>@(cycle.EndDate?.ToString("MMM dd, yyyy") ?? "Ongoing")</td>
                        <td>@cycleLenStr</td>
                        <td class="bold" style="color: #64748B;">@(cycle.Flow ?? "Medium")</td>
                        <td class="actions" style="border: none;">
                            <div style="display: flex; gap: 0.75rem; align-items: center; justify-content: flex-start;">
                                <button type="button" class="action-btn-v3" title="Edit" onclick="openEditModal(@cycle.Id, '@cycle.StartDate.ToString("yyyy-MM-dd")', '@(cycle.EndDate?.ToString("yyyy-MM-dd") ?? "")', '@(cycle.Flow ?? "Medium")')" style="background: #F1F5F9; border: none; cursor: pointer; color: #475569; padding: 8px; border-radius: 8px; transition: all 0.2s; display: flex; align-items: center; justify-content: center;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </button>
                                <form id="deleteForm-@cycle.Id" asp-controller="Dashboard" asp-action="DeleteCycle" method="post" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@cycle.Id" />
                                    <button type="button" class="action-btn-v3 delete" title="Delete" onclick="openDeleteModal(@cycle.Id)" style="background: #FEF2F2; border: none; cursor: pointer; color: #EF4444; padding: 8px; border-radius: 8px; transition: all 0.2s; display: flex; align-items: center; justify-content: center;">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Insights Bar -->
    <div class="insights-bar-v3">
        <div class="insights-header-v3">
            <span class="insights-icon-v3">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                    <rect x="4" y="4" width="4" height="16" fill="#D32F2F"/>
                    <rect x="10" y="4" width="4" height="16" fill="#388E3C"/>
                    <rect x="16" y="4" width="4" height="16" fill="#1976D2"/>
                </svg>
            </span>
            <h3>Cycle Insights</h3>
        </div>
        <div class="insights-grid-v3">
            <div class="insight-column-v3">
                <span class="insight-label-v3">Regularity</span>
                <span class="insight-value-v3">@ViewBag.Regularity</span>
                <span class="insight-detail-v3">@ViewBag.RegularityDetail</span>
            </div>
            <div class="insight-column-v3">
                <span class="insight-label-v3">Most Common Flow</span>
                <span class="insight-value-v3">@ViewBag.CommonFlow</span>
                <span class="insight-detail-v3">@ViewBag.FlowDetail</span>
            </div>
            <div class="insight-column-v3">
                <span class="insight-label-v3">Prediction Accuracy</span>
                <span class="insight-value-v3">95%</span>
                <span class="insight-detail-v3">Based on @ViewBag.TotalCycles cycles</span>
            </div>
        </div>
    </div>
</div>

<!-- Custom Delete Confirm Modal -->
<div id="deleteConfirmModal" class="modal-overlay-v3" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px);">
    <div class="modal-card-v3" style="background: white; padding: 2rem; border-radius: 1rem; width: 90%; max-width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); text-align: center;">
        <div style="width: 50px; height: 50px; border-radius: 50%; background: #FEE2E2; color: #EF4444; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
        <h2 style="margin-bottom: 0.5rem; color: #1E293B; font-size: 1.25rem;">Delete Cycle</h2>
        <p style="color: #64748B; margin-bottom: 1.5rem; font-size: 0.95rem;">Are you sure you want to delete this cycle? This action cannot be undone.</p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
            <button type="button" onclick="closeDeleteModal()" style="padding: 0.75rem 1.5rem; border: 1px solid #CBD5E1; background: white; border-radius: 0.5rem; cursor: pointer; font-weight: 600; color: #475569;">Cancel</button>
            <button type="button" id="confirmDeleteBtn" style="padding: 0.75rem 1.5rem; border: none; background: #EF4444; color: white; border-radius: 0.5rem; cursor: pointer; font-weight: 600;">Delete</button>
        </div>
    </div>
</div>

<!-- Edit Cycle Modal -->
<div id="editCycleModal" class="modal-overlay-v3" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px);">
    <div class="modal-card-v3" style="background: white; padding: 2rem; border-radius: 1rem; width: 90%; max-width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
        <h2 style="margin-bottom: 1.5rem; color: #1E293B; font-size: 1.25rem;">Edit Cycle</h2>
        <form asp-controller="Dashboard" asp-action="EditCycle" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editCycleId" />
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-weight: 600; font-size: 0.9rem; color: #475569; margin-bottom: 0.5rem;">Start Date</label>
                <input type="date" name="startDate" id="editStartDate" required style="width: 100%; padding: 0.75rem; border: 1px solid #CBD5E1; border-radius: 0.5rem; box-sizing: border-box;" />
            </div>
            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; font-weight: 600; font-size: 0.9rem; color: #475569; margin-bottom: 0.5rem;">End Date (Optional)</label>
                <input type="date" name="endDate" id="editEndDate" style="width: 100%; padding: 0.75rem; border: 1px solid #CBD5E1; border-radius: 0.5rem; box-sizing: border-box;" />
            </div>
            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; font-weight: 600; font-size: 0.9rem; color: #475569; margin-bottom: 0.5rem;">Flow Intensity</label>
                <select name="flow" id="editFlow" style="width: 100%; padding: 0.75rem; border: 1px solid #CBD5E1; border-radius: 0.5rem; box-sizing: border-box; background: white;">
                    <option value="Light">Light</option>
                    <option value="Medium">Medium</option>
                    <option value="Heavy">Heavy</option>
                </select>
            </div>
            <div style="display: flex; gap: 1rem;">
                <button type="button" onclick="closeEditModal()" style="flex: 1; padding: 0.75rem; border: 1px solid #CBD5E1; background: white; border-radius: 0.5rem; cursor: pointer; font-weight: 600; color: #475569;">Cancel</button>
                <button type="submit" style="flex: 1; padding: 0.75rem; border: none; background: #0EA5E9; color: white; border-radius: 0.5rem; cursor: pointer; font-weight: 600;">Save Changes</button>
            </div>
        </form>
    </div>
</div>


<script>
    let currentDeleteId = null;


    function openDeleteModal(id) {
        currentDeleteId = id;
        document.getElementById('deleteConfirmModal').style.display = 'flex';
    }

    function closeDeleteModal() {
        currentDeleteId = null;
        document.getElementById('deleteConfirmModal').style.display = 'none';
    }

    document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
        if (currentDeleteId) {
            document.getElementById('deleteForm-' + currentDeleteId).submit();
        }
    });

    function openEditModal(id, startDate, endDate, flow) {
        document.getElementById('editCycleId').value = id;
        document.getElementById('editStartDate').value = startDate;
        document.getElementById('editEndDate').value = endDate;
        document.getElementById('editFlow').value = flow || "Medium";
        document.getElementById('editCycleModal').style.display = 'flex';
    }

    function closeEditModal() {
        document.getElementById('editCycleModal').style.display = 'none';
    }
</script>
